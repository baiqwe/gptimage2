# ==============================================
# GPT Image 2 Generator Environment Variables
# ==============================================

# Supabase Configuration
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI image generation API (Required for GPT Image 2 generation)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Kie.ai GPT Image 2 API (Optional alternative provider)
# Docs: https://docs.kie.ai/
# If KIE_API_KEY is set, the app will prefer Kie.ai over OpenAI
KIE_API_KEY=
KIE_API_BASE_URL=https://api.kie.ai

# Creem Payment Configuration
# Get your credentials from https://creem.io
CREEM_WEBHOOK_SECRET=
CREEM_API_KEY=
CREEM_API_URL=https://test-api.creem.io/v1

# Site URLs (Update for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BASE_URL=localhost:3000
CREEM_SUCCESS_URL=http://localhost:3000/en/create

# Optional: OpenRouter for additional AI features or scripts
OPENROUTER_API_KEY=

# ==============================================
# Production Configuration (uncomment for prod)
# ==============================================
# CREEM_API_URL=https://api.creem.io/v1
# NEXT_PUBLIC_SITE_URL=https://gptimage2.online
# CREEM_SUCCESS_URL=https://gptimage2.online/en/create
